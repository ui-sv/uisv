{
	"name": "uisv",
	"version": "0.0.21",
	"description": "ui library for the rest of us",
	"license": "MIT",
	"repository": "ui-sv/uisv",
	"homepage": "https://uisv.pages.dev",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build && npm run prepack",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"prepack": "svelte-kit sync && svelte-package && publint",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run"
	},
	"files": [
		"dist",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*"
	],
	"sideEffects": [
		"**/*.css"
	],
	"svelte": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js",
			"style": "./dist/runtime/index.css",
			"default": "./dist/index.js"
		},
		"./vite": {
			"types": "./dist/vite.d.ts",
			"svelte": "./dist/vite.js",
			"default": "./dist/vite.js"
		},
		"./date": {
			"types": "./dist/date.d.ts",
			"svelte": "./dist/date.js",
			"default": "./dist/date.js"
		},
		"./mode": {
			"types": "./dist/mode.d.ts",
			"svelte": "./dist/mode.js",
			"default": "./dist/mode.js"
		}
	},
	"peerDependencies": {
		"svelte": "^5.0.0"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.5",
		"@eslint/js": "^10.0.1",
		"@iconify-json/lucide": "^1.2.105",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.59.1",
		"@sveltejs/package": "^2.5.7",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@types/node": "^25.6.1",
		"@vitest/browser": "^4.1.5",
		"eslint": "^10.3.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.1",
		"globals": "^17.6.0",
		"playwright": "^1.59.1",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.5.1",
		"publint": "^0.3.19",
		"svelte": "^5.55.5",
		"svelte-check": "^4.4.8",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.59.2",
		"vite": "^7.3.3",
		"vitest": "^4.1.5",
		"vitest-browser-svelte": "^2.1.1"
	},
	"dependencies": {
		"@internationalized/date": "^3.12.1",
		"@unocss/preset-web-fonts": "^66.6.8",
		"@unocss/svelte-scoped": "^66.6.8",
		"bits-ui": "^2.18.1",
		"colortranslator": "^6.1.1",
		"defu": "^6.1.7",
		"devalue": "^5.8.0",
		"maska": "^3.2.0",
		"mlly": "^1.8.2",
		"mode-watcher": "^1.1.0",
		"runed": "^0.37.1",
		"scule": "^1.3.0",
		"tailwind-variants": "^3.2.2",
		"theme-colors": "^0.1.0",
		"unocss": "^66.6.8"
	},
	"keywords": [
		"svelte",
		"ui"
	]
}
